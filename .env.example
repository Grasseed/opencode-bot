BOT_TOKEN=
OPENCODE_MODEL=provider/model-name
OPENCODE_VARIANT=medium
OPENCODE_PERMISSION_MODE=ask
OPENCODE_WORKDIR=/path/to/OpenFox
STATE_FILE=/path/to/OpenFox/data/state.json
TELEGRAM_POLL_TIMEOUT_SECONDS=30
TELEGRAM_POLL_RETRY_DELAY_MS=1500
OPENCODE_TIMEOUT_MS=600000
DELETE_WEBHOOK_ON_START=true
TELEGRAM_SKIP_PENDING_UPDATES_ON_START=true
TELEGRAM_ALLOW_GROUPS=false
PORT=3000
TELEGRAM_WEBHOOK_PATH=/webhook
